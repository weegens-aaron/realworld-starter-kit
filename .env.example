# Conduit environment configuration — copy to `.env` and tweak as needed.
#
#   cp .env.example .env
#
# `.env` is git-ignored; THIS file (.env.example) is the committed, documented
# template. backend/core/config.py loads `.env` automatically via
# pydantic-settings, so anything set here is picked up on boot. Every value
# below has a working default baked into the app/compose, so an untouched copy
# runs against the default `docker compose up` Postgres out of the box.

# --- Database --------------------------------------------------------------
# SQLAlchemy connection URL read by backend/core/db.py. The driver is
# normalised to asyncpg automatically, so postgres://, postgresql:// and
# postgresql+asyncpg:// all work. Must point at the Postgres started by
# compose.yml (host localhost:5432 by default).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/conduit

# --- Postgres container knobs (read by compose.yml) ------------------------
# These configure the postgres image's first-boot init. Keep them consistent
# with DATABASE_URL above — if you change the user/password/db/port here, mirror
# the change in DATABASE_URL or the app won't be able to connect.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=conduit
POSTGRES_PORT=5432

# --- Auth / JWT ------------------------------------------------------------
# Signing secret for issued JWTs (backend/core/security.py). The app ships an
# obviously-insecure default for dev; you MUST override this with a long random
# value in any shared/staging/prod environment, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
CONDUIT_JWT_SECRET=dev-insecure-change-me-please-override-in-prod

# --- App behaviour ---------------------------------------------------------
# Flip on for verbose SQL echo + FastAPI debug. Leave off in prod.
CONDUIT_DEBUG=false
